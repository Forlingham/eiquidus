  // default_coingecko_ids: 与 coingecko api 符号和 id 列表相关的设置集合
  //                        向此部分添加条目将强制将特定硬币符号关联到 coingecko id，当使用 coingecko api 进行美元查找以及使用 markets_page.market_price = "COINGECKO" 选项时
  //                        当 coingecko api 中有多个具有相同符号的硬币时，这很有用，因为默认情况下，浏览器将匹配列表中的第一个，这可能并不总是正确的硬币
  //                        访问 coingecko 硬币列表 api 手动查找要在浏览器中使用的符号的正确 id: https://api.coingecko.com/api/v3/coins/list?include_platform=false
  //                        您可以按以下格式添加任意数量的 coingecko id 默认值: [ { "symbol": "btc", "id": "bitcoin" }, { "symbol": "eth", "id": "ethereum" } ]
  //                        注意: 如果浏览器需要通过 coingecko 硬币列表 api 查找的所有符号都在此处默认设置，则市场同步将保存一个 api 调用，并跳过调用 coingecko 硬币列表 api
  "default_coingecko_ids": [
    { "symbol": "btc", "id": "bitcoin" },
    { "symbol": "eth", "id": "ethereum" },
    { "symbol": "usdt", "id": "tether" },
    { "symbol": "ltc", "id": "litecoin" },
    { "symbol": "exor", "id": "exor" },
    { "symbol": "scash", "id": "satoshi-cash-network" }
  ],

  //api_cmds: 与可自定义 rpc api 命令列表相关的设置集合
  //          并非所有区块链都使用相同的 rpc 命令来访问内部守护进程 api。使用这些设置可为类似的 api 命令设置替代名称。
  //          将命令值留空 ( "" ) 将完全禁用该命令的使用。
  //          注意: 某些 api（例如 getblockhash）对于浏览器的功能是不可或缺的，如果禁用将导致相当不可用的体验。
  "api_cmds": {
    // use_rpc: 确定是否直接使用更快的 rpc 方法调用 rpc api 命令，或通过内部 http api 使用旧方法 (true/false)
    //          注意: 除非有特定需要测试或记录某些 api，否则应始终将其设置为 true
    "use_rpc": true,
    // rpc_concurrent_tasks: 可以同时运行的最大 rpc 命令数。额外的 rpc 命令将进入队列并按先入先出的基础运行
    "rpc_concurrent_tasks": 1,
    // getnetworkhashps: 返回估计的网络每秒哈希数。这应该是一个正整数
    "getnetworkhashps": "getnetworkhashps",
    // getmininginfo: 返回包含挖矿相关信息的 json 对象
    "getmininginfo": "getmininginfo",
    // getdifficulty: 返回工作量证明难度作为最小难度的倍数。这应该是一个正整数或小数
    "getdifficulty": "getdifficulty",
    // getconnectioncount: 返回与其他节点的连接数。这应该是一个正整数
    "getconnectioncount": "getconnectioncount",
    // getblockcount: 返回最长区块链中的区块数。这应该是一个正整数
    "getblockcount": "getblockcount",
    // getblockhash: 返回提供的最佳区块链高度处的区块哈希。这应该是一个字符串值
    "getblockhash": "getblockhash",
    // getblock: 返回包含有关特定区块信息的对象
    "getblock": "getblock",
    // getrawtransaction: 返回原始交易数据。可以根据 decrypt 值（0 = false 或 1 = true）返回序列化的十六进制编码字符串或带有 txid 信息的对象
    "getrawtransaction": "getrawtransaction",
    // getinfo: 返回包含各种状态信息的对象
    "getinfo": "getinfo",
    // getblockchaininfo: 返回包含有关区块链处理的各种状态信息的对象
    "getblockchaininfo": "getblockchaininfo",
    // getpeerinfo: 返回有关每个连接的网络节点的数据，作为对象的 json 数组
    "getpeerinfo": "getpeerinfo",
    // gettxoutsetinfo: 返回有关未花费交易输出集的统计信息的对象
    "gettxoutsetinfo": "gettxoutsetinfo",
    // getvotelist: 返回有关当前投票列表详细信息的对象
    "getvotelist": "masternodelist votes",
    // getmasternodecount: 返回包含网络上主节点总数的 json 对象
    "getmasternodecount": "getmasternodecount",
    // getmasternodelist: 返回包含网络上所有主节点状态信息的 json 数组
    "getmasternodelist": "listmasternodes",
    // verifymessage: 验证签名消息。必须接受以下参数:
    //                address: 用于签名的钱包地址
    //                signature: 签名者提供的 base 64 编码签名
    //                message: 被签名的消息
    "verifymessage": "verifymessage"
  }
}
