/*
  此文件必须是有效的 JSON。但也允许注释

  请编辑 settings.json，而不是 settings.json.template
*/
{
  // locale: 更改语言定义。目前仅支持英语
  "locale": "locale/en.json",

  "dbsettings": {
    "user": "eiquidus",
    "password": "eiquiduspassword",
    "database": "scash-explorer",
    "address": "localhost",
    "port": 27017
  },
  "wallet": {
    "host": "localhost",
    "port": 9645,
    "username": "scash123",
    "password": "YourStrongPassword"
  },
  "webserver": {
    "port": 3009,
    "tls": {
      "enabled": false,
      "port": 443,
      "always_redirect": true,
      "cert_file": "/etc/letsencrypt/live/scash.tv/cert.pem",
      "chain_file": "/etc/letsencrypt/live/scash.tv/chain.pem",
      "key_file": "/etc/letsencrypt/live/scash.tv/privkey.pem"
    },
    "cors": {
      "enabled": true,
      "corsorigin": "*"
    }
  },

  // coin: 与正在浏览的加密货币相关的设置集合
  "coin": {
    // name: 正在浏览的加密货币硬币名称。当 "shared_pages.page_header.home_link" 设置为 "coin" 时，此值显示在页面标题中。
    //       注意：此值作为 mongo 中存储的数据的唯一标识符，因此如果不重新同步所有现有数据，则无法更改。
    "name": "Scash",
    // symbol: 加密货币硬币代码/符号值。此值显示在显示硬币数据的任何位置，包括索引、地址、块、移动、奖励、富豪榜/前 100 名和 tx 页面
    "symbol": "SCASH"
  },

  // scash_dap: scash-dap 数据协议的配置
  "scash_dap": {
    "enabled": true,
    "bech32": "scash",
  "bip32": {
    "public": "0x0488b21e",
    "private": "0x0488ade4"
  },
  "pubKeyHash": "0x3c",
  "scriptHash": "0x7d",
  "wif": "0x80"
  },

  // network_history: 一组设置，用于控制在块同步期间保存额外的历史网络数据
  "network_history": {
    // enabled: 启用/禁用保存额外的网络历史数据（true/false）
    //          如果设置为 false，则不会保存网络哈希率和难度值等历史数据，也不会用于网络图表
    "enabled": true,
    // max_saved_records: 保存历史数据的最大块数。如果使用 max_hours 选项，请将此值设置为 0
    "max_saved_records": 120,
    // max_hours: 保存历史数据的最大小时数。max_saved_records 值将取代此值，因此如果想显示一定小时数的数据，请务必将 max_saved_records 设置为 0
    "max_hours": 24
  },

  /* 共享页面设置 */
 
  // shared_pages: 与浏览器的所有网页相关的设置集合
  "shared_pages": {
    // theme: 使用唯一的主题更改浏览器的外观和感觉。使用 bootswatch 主题 (https://bootswatch.com)
    //        有效选项：Cerulean, Cosmo, Cyborg, Darkly, Exor, Flatly, Journal, Litera, Lumen, Lux, Materia, Minty, Morph, Pulse, Quartz, Sandstone, Simplex, Sketchy, Slate, Solar, Spacelab, Superhero, United, Vapor, Yeti, Zephyr
    //        (查看 /public/css/themes 以获取可用主题)
    "theme": "scash",
    // page_title: 显示在 HTML 标题标签末尾的文本，当 "shared_pages.page_header.home_link" 设置为 "title" 时，也会显示在页面标题中
    "page_title": "eIquidus",
    // favicons: 一组图像或图标文件，显示在浏览器窗口/选项卡中，用作网站的品牌标识。其主要目的是帮助访问者在打开多个选项卡时更容易找到您的页面
    //          现代 favicon 尺寸受到这篇网络文章的启发：https://www.emergeinteractive.com/insights/detail/The-Essentials-of-FavIcons/
    //          注意：如果任何 favicon 留空或未设置为有效文件，则它们将被禁用且不被使用
    "favicons": {
      // favicon32: 32x32 图像或图标文件的路径
      //            注意：路径根目录为 /public
      "favicon32": "favicon-32.png",
      // favicon128: 128x128 图像或图标文件的路径
      //            注意：路径根目录为 /public
      "favicon128": "favicon-128.png",
      // favicon180: 180x180 图像或图标文件的路径
      //            注意：路径根目录为 /public
      "favicon180": "favicon-180.png",
      // favicon192: 192x192 图像或图标文件的路径
      //            注意：路径根目录为 /public
      "favicon192": "favicon-192.png"
    },
    // logo: 图像文件的路径，该图像显示在 api 页面上，以及启用时的顶部面板之一中
    //       当 "shared_pages.page_header.home_link" 设置为 "logo" 且 "shared_pages.page_header.home_link_logo" 设置为空或无效文件时，此徽标也可以显示在标题中
    //       注意：路径根目录为 /public
    //             最佳徽标大小为 128x128，因为图像在显示时将被强制为 128px 高
    "logo": "/img/logo.png",
    // date_time: 与浏览器中显示的日期和时间值相关的设置集合
    "date_time": {
      // display_format: 显示日期/时间值时使用的格式
      //                 日期/时间值使用 Luxon 库格式化，必须遵循正确的语法（阅读更多：https://moment.github.io/luxon/#/formatting?id=table-of-tokens）
      //                 例如：LLL dd, yyyy HH:mm:ss ZZZZ = May 27, 2019 22:04:11 UTC
      "display_format": "LLL dd, yyyy HH:mm:ss ZZZZ",
      // timezone: 所有日期和时间都存储为 UTC 日期，既可以以 UTC 格式显示，也可以根据用户的 Web 浏览器设置以本地时区显示
      //           有效选项：utc 或 local
      "timezone": "utc",
      // enable_alt_timezone_tooltips: 确定日期和时间是否应具有鼠标悬停工具提示，该提示显示备用时区值
      //                               如果设置为 true 且 "shared_pages.date_time.timezone" 设置为 "utc"，则启用此选项将显示本地浏览器时区的日期/时间工具提示
      //                               如果设置为 true 且 "shared_pages.date_time.timezone" 设置为 "local"，则启用此选项将显示 UTC 时区的日期/时间工具提示
      //                               如果设置为 false，则不会显示任何日期/时间值的工具提示
      "enable_alt_timezone_tooltips": false
    },
    // table_header_bgcolor: 更改所有表格标题的背景颜色
    //                       有效选项：light, dark 或留空 ( "" ) 以使用默认颜色
    "table_header_bgcolor": "",
    // confirmations: 在块或交易被视为有效之前的确认数
    //                如果确认数 >= 此值，则块或 tx 被视为有效并显示为绿色
    //                如果确认数 < 此值超过 50%，则块或 tx 被视为未确认并显示为红色
    //                如果确认数 < 此值少于 50%，则块或 tx 被视为未确认并显示为橙色
    "confirmations": 40,
    // difficulty: 确定要显示的网络难度值（有效选项为：POW, POS 或 Hybrid）
    //             某些区块链根据可用的 POW/POS 选项显示不同的难度值：
    //             POW: 显示工作量证明难度值
    //             POS: 显示权益证明难度值
    //             Hybrid: 同时显示工作量证明和权益证明难度值
    "difficulty": "POS",
    // show_hashrate: 确定是否在适用的地方显示网络哈希率（true/false）
    //                如果设置为 false，/api/getnetworkhashps 和 /ext/getsummary api 将不再显示哈希率信息，并且网络哈希率图表将自动禁用
    "show_hashrate": true,
    // page_header: 一组设置，与显示在所有页面顶部的页面标题相关
    "page_header": {
      // menu: 有效选项：
      //       top: 在页面顶部水平显示菜单项
      //       side: 在页面左侧垂直显示菜单项
      "menu": "side",
      // sticky_header: 确定页面标题是否“粘贴”到页面顶部（true/false）
      "sticky_header": true,
      // bgcolor: 更改页面标题的背景颜色
      //          有效选项：light, dark, primary, secondary, success, info, warning, danger 或留空 ( "" ) 以使用默认颜色
      "bgcolor": "",
      // home_link: 主页链接设置确定在标题菜单左上角显示的内容。有效选项：
      //            title: 显示 "shared_pages.page_title" 文本设置
      //            coin: 显示 "coin.name" 文本设置
      //            logo: 如果 "shared_pages.page_header.home_link_logo" 设置为有效图像，则显示该图像，否则显示 "shared_pages.logo" 图像
      "home_link": "logo",
      // home_link_logo: 当 "shared_pages.page_header.home_link" 设置为 "logo" 时，显示在页面标题上的徽标图像的路径
      //                 如果 home_link_logo 留空或未设置为有效文件，则 "shared_pages.page_header.home_link" = "logo" 设置将自动默认显示原始 "shared_pages.logo" 而不是 "shared_pages.page_header.home_link_logo"
      //                 注意：路径根目录为 /public
      "home_link_logo": "/img/header-logo.png",
      // home_link_logo_height: "shared_pages.page_header.home_link" 徽标图像的最大高度值（以像素为单位，仅当 "shared_pages.page_header.home_link" = 'logo' 时有效）
      "home_link_logo_height": 50,
      // panels: 一组设置，与显示在所有页面标题上的面板相关（注意：您可以通过更改每个页面设置中的 show_panels 值来独立显示/隐藏每个页面上的整个面板组）
      //         页面顶部最多可以同时显示 5 个面板，因此如果启用了超过 5 个面板，则仅显示前 5 个
      "panels": {
        // network_panel: 一组设置，与显示当前网络哈希率的网络面板相关（仅适用于 POW 硬币）
        "network_panel": {
          // enabled: 启用/禁用网络面板（true/false）
          //          如果设置为 false，则网络面板将完全不可访问
          "enabled": false,
          // display_order: 确定此面板的显示顺序，从 1-5
          //                1 = 最左侧面板，5 = 最右侧面板
          //                值为 0 将禁用该面板
          "display_order": 0,
          // nethash: 确定如何获取网络哈希率。有效选项：
          //          getnetworkhashps: 从 getnetworkhashps rpc cmd 获取
          //          netmhashps: 从 getmininginfo rpc cmd 获取
          "nethash": "getnetworkhashps",
          // nethash_units: 确定应用于显示网络哈希率的单位。有效选项：
          //                P: 以 petahashes (PH/s) 显示值
          //                T: 以 terahashes (TH/s) 显示值
          //                G: 以 gigahashes (GH/s) 显示值
          //                M: 以 megahashes (MH/s) 显示值
          //                K: 以 kilohashes (KH/s) 显示值
          //                H: 以 hashes (H/s) 显示值
          "nethash_units": "G"
        },
        // difficulty_panel: 一组设置，与显示当前工作量证明难度的难度面板相关（仅适用于 POW 硬币）
        "difficulty_panel": {
          // enabled: 启用/禁用难度面板（true/false）
          //          如果设置为 false，则难度面板将完全不可访问
          "enabled": false,
          // display_order: 确定此面板的显示顺序，从 1-5
          //                1 = 最左侧面板，5 = 最右侧面板
          //                值为 0 将禁用该面板
          "display_order": 0
        },
        // masternodes_panel: 一组设置，与显示在线和不可访问主节点计数的主节点面板相关（仅适用于主节点硬币）
        "masternodes_panel": {
          // enabled: 启用/禁用主节点面板（true/false）
          //          如果设置为 false，则主节点面板将完全不可访问
          "enabled": true,
          // display_order: 确定此面板的显示顺序，从 1-5
          //                1 = 最左侧面板，5 = 最右侧面板
          //                值为 0 将禁用该面板

          "display_order": 2
        },
        // coin_supply_panel: 一组设置，与显示当前流通硬币供应值的硬币供应面板相关
        "coin_supply_panel": {
          // enabled: 启用/禁用硬币供应面板（true/false）
          //          如果设置为 false，则硬币供应面板将完全不可访问
          "enabled": true,
          // display_order: 确定此面板的显示顺序，从 1-5
          //                1 = 最左侧面板，5 = 最右侧面板
          //                值为 0 将禁用该面板
          "display_order": 1
        },
        // price_panel: 一组设置，与显示当前市场价格（由 markets_page.market_price 值确定）的价格面板相关
        "price_panel": {
          // enabled: 启用/禁用价格面板（true/false）
          //          如果设置为 false，则价格面板将完全不可访问
          "enabled": true,
          // display_order: 确定此面板的显示顺序，从 1-5
          //                1 = 最左侧面板，5 = 最右侧面板
          //                值为 0 将禁用该面板
          "display_order": 0
        },
        // usd_price_panel: 一组设置，与显示以美元衡量的当前市场价格的美元价格面板相关
        "usd_price_panel": {
          // enabled: 启用/禁用美元价格面板（true/false）
          //          如果设置为 false，则美元价格面板将完全不可访问
          "enabled": true,
          // display_order: 确定此面板的显示顺序，从 1-5
          //                1 = 最左侧面板，5 = 最右侧面板
          //                值为 0 将禁用该面板
          "display_order": 4
        },
        // market_cap_panel: 一组设置，与显示当前市值（由 markets_page.market_price 值确定）的市值面板相关
        "market_cap_panel": {
          // enabled: 启用/禁用市值面板（true/false）
          //          如果设置为 false，则市值面板将完全不可访问
          "enabled": false,
          // display_order: 确定此面板的显示顺序，从 1-5
          //                1 = 最左侧面板，5 = 最右侧面板
          //                值为 0 将禁用该面板
          "display_order": 0
        },
        // usd_market_cap_panel: 一组设置，与显示以美元衡量的当前市值的市值面板相关
        "usd_market_cap_panel": {
          // enabled: 启用/禁用美元市值面板（true/false）
          //          如果设置为 false，则美元市值面板将完全不可访问
          "enabled": true,
          // display_order: 确定此面板的显示顺序，从 1-5
          //                1 = 最左侧面板，5 = 最右侧面板
          //                值为 0 将禁用该面板
          "display_order": 5
        },
        // logo_panel: 一组设置，与显示 "shared_pages.logo" 图像的徽标面板相关
        "logo_panel": {
          // enabled: 启用/禁用徽标面板（true/false）
          //          如果设置为 false，则徽标面板将完全不可访问
          "enabled": true,
          // display_order: 确定此面板的显示顺序，从 1-5
          //                1 = 最左侧面板，5 = 最右侧面板
          //                值为 0 将禁用该面板
          "display_order": 3
        },
        // spacer_panel_1: 一组设置，与允许在顶部面板中插入空白空间的第 1 个间隔面板相关
        //                 注意：间隔面板仅在桌面和平板电脑屏幕尺寸上可见，在移动屏幕上隐藏
        "spacer_panel_1": {
          // enabled: 启用/禁用间隔面板（true/false）
          //          如果设置为 false，则间隔面板将完全不可访问
          "enabled": false,
          // display_order: 确定此面板的显示顺序，从 1-5
          //                1 = 最左侧面板，5 = 最右侧面板
          //                值为 0 将禁用该面板
          "display_order": 0
        },
        // spacer_panel_2: 一组设置，与允许在顶部面板中插入空白空间的第 2 个间隔面板相关
        //                 注意：间隔面板仅在桌面和平板电脑屏幕尺寸上可见，在移动屏幕上隐藏
        "spacer_panel_2": {
          // enabled: 启用/禁用间隔面板（true/false）
          //          如果设置为 false，则间隔面板将完全不可访问
          "enabled": false,
          // display_order: 确定此面板的显示顺序，从 1-5
          //                1 = 最左侧面板，5 = 最右侧面板
          //                值为 0 将禁用该面板
          "display_order": 0
        },
        // spacer_panel_3: 一组设置，与允许在顶部面板中插入空白空间的第 3 个间隔面板相关
        //                 注意：间隔面板仅在桌面和平板电脑屏幕尺寸上可见，在移动屏幕上隐藏
        "spacer_panel_3": {
          // enabled: 启用/禁用间隔面板（true/false）
          //          如果设置为 false，则间隔面板将完全不可访问
          "enabled": false,
          // display_order: 确定此面板的显示顺序，从 1-5
          //                1 = 最左侧面板，5 = 最右侧面板
          //                值为 0 将禁用该面板
          "display_order": 0
        }
      },
      // search: 一组设置，与搜索功能相关
      "search": {
        // enabled: 启用/禁用搜索浏览器网站的功能（true/false）
        //          如果设置为 false，浏览器将不显示搜索框或响应搜索查询
        "enabled": true,
        // position: 确定搜索框应在网站上显示的位置
        //           有效选项：inside-header, below-header
        "position": "inside-header"
      },
      // page_title_image: 一组设置，与每个页面的页面标题图像相关
      "page_title_image": {
        // image_path: 图像文件的路径，该图像显示在所有页面的标题部分，紧挨着页面标题（注意：可以基于每个页面启用/禁用此图像）
        //             注意：路径根目录为 /public
        //             最佳徽标大小为 48x48，因为图像在显示时将被强制为该大小
        "image_path": "/img/page-title-img.png",
        // enable_animation: 启用/禁用页面标题图像上的翻转/旋转动画（true/false）
        "enable_animation": true
      },
      // network_charts: 一组设置，与显示在所有页面标题上的网络哈希率和难度折线图相关
      //                 注意：您可以通过更改每个页面设置中的 show_nethash_chart 和 show_difficulty_chart 值来独立显示/隐藏各个图表
      //                       "network_history.enabled" 设置必须设置为 true，以便网络图表正常工作
      //                       如果 "network_history.enabled" 设置为 false，则无论其独立设置如何，所有网络图表都将被完全禁用
      "network_charts": {
        // nethash_chart: 一组设置，与网络哈希率图表相关
        "nethash_chart": {
          // enabled: 启用/禁用网络哈希率图表（true/false）
          //          如果设置为 false，则网络哈希率图表将完全不可访问
          //          注意：`shared_pages.show_hashrate` 选项必须设置为 true，否则网络哈希率图表将完全不可访问
          "enabled": true,
          // chart_title: 一组设置，与图表标题相关
          "chart_title": {
            // enabled: 启用/禁用图表标题（true/false）
            //          如果设置为 false，则图表标题将完全从图表中消失
            "enabled": false,
            // title_text: 要在图表标题中显示的文本
            //             注意：您可以添加 "/n" 字符进行回车
            //             以下关键字可用于图表标题：
            //             {coin_name}: 显示 `coin.name` 设置中的硬币名称
            //             {max_saved_records}: 显示图表显示数据的记录数，来自 `network_history.max_saved_records` 设置
            //             {max_hours}: 显示图表显示数据的小时数，来自 `network_history.max_hours` 设置
            //             {current_nethash}: 显示网络图表数据中最近的 nethash 值
            //             {highest_nethash}: 显示网络图表数据中的最高 nethash 值
            //             {lowest_nethash}: 显示网络图表数据中的最低 nethash 值
            //             {highest_block}: 显示网络图表数据中的最高块高度值
            //             {lowest_block}: 显示网络图表数据中的最低块高度值
            "title_text": "{coin_name} Network Hashrate History for the last {max_hours} hours\nHigh: {highest_nethash}\nCurrent: {current_nethash}\nLow: {lowest_nethash}\nBlock: {highest_block}",
            // alignment: 确定如何水平对齐图表标题文本
            //            有效选项为 left, center 和 right
